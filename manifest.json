{
  "manifest_version": 3,
  "name": "BasedBot Discipline",
  "version": "1.9.0",
  "description": "Risk-ranked Pulse feed, position discipline, trade journal, anti-FOMO and dev/dump alerts for BasedBot.",
  "permissions": ["storage", "notifications", "unlimitedStorage"],
  "host_permissions": ["https://basedbot.app/*", "https://api.telegram.org/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BasedBot Discipline",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://basedbot.app/*"],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://basedbot.app/*"],
      "js": [
        "src/constants.js",
        "src/store.js",
        "src/feed.js",
        "src/creator.js",
        "src/journal.js",
        "src/score.js",
        "src/filter.js",
        "src/intel.js",
        "src/pnl.js",
        "src/banner.js",
        "src/guard.js",
        "src/dump.js",
        "src/main.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
